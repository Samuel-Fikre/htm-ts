{
  "name": "htm-ts",
  "version": "0.0.4",
  "type": "module",
  "description": "Surgically reactive, type-safe tagged template engine with signals and fine-grained updates.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:dist": "pnpm build && node -e \"import('./dist/index.js').then(() => console.log('✅ Dist build importable!'))\"",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "keywords": [
    "reactive",
    "signals",
    "htm",
    "tagged-templates",
    "fine-grained",
    "typescript",
    "no-vdom",
    "surgical"
  ],
  "author": "Samuel Fikre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Samuel-Fikre/htm-ts"
  },
  "homepage": "https://github.com/Samuel-Fikre/htm-ts",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}